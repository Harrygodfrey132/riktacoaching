{{- $seen := newScratch -}}
{{- $allPages := .Site.AllPages -}}
<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{- $enHomeURL := partial "seo-url.html" (dict "page" .Site.Home "path" "/") -}}
  {{- $seen.Set $enHomeURL true -}}
  <url>
    <loc>{{ $enHomeURL }}</loc>
  </url>
  {{- range $allPages }}
    {{- if and (hasPrefix .RelPermalink "/") (not .Params.noindex) }}
      {{- $url := partial "seo-url.html" (dict "page" .) -}}
      {{- if not ($seen.Get $url) -}}
        {{- $seen.Set $url true -}}
  <url>
    <loc>{{ $url }}</loc>
    {{- with .Lastmod }}
    <lastmod>{{ .Format "2006-01-02T15:04:05-07:00" }}</lastmod>
    {{- end }}
  </url>
      {{- end -}}
    {{- end -}}
  {{- end }}
</urlset>
